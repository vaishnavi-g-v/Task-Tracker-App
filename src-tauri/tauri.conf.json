{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Task Tracker",
  "version": "0.1.0",
  "identifier": "com.local.tasktracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Task Tracker",
        "width": 1200,
        "height": 780,
        "resizable": true,
        "visible": true
      },
      {
        "label": "widget",
        "title": "Task Widget",
        "width": 360,
        "height": 520,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
